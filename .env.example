# Banco de Dados
DATABASE_URL=file:./db/wedding.db

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# Google OAuth (get from Google Cloud Console)

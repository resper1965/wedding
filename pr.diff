-// Wedding Guest Management Platform - Schema
-// Plataforma elegante para gestão de convidados de casamento
-// Version: 2.0 - Wedding Concierge (WhatsApp AI Integration)
-
-generator client {
-  provider = "prisma-client-js"
-}
-
-datasource db {
-  provider = "postgresql"
-  url      = env("POSTGRES_URL")
-}
-
-// ============================================================================
-// CORE - Evento Principal
-// ============================================================================
-
-model Wedding {
-  id            String   @id @default(cuid())
-  
-  // Informações do Casal
-  partner1Name  String
-  partner2Name  String
-  
-  // Data e Local
-  weddingDate   DateTime
-  venue         String?
-  venueAddress  String?
-  
-  // Configurações de comunicação
-  replyByDate   DateTime?
-  messageFooter String?   // Mensagem personalizada nos convites
-  
-  // Estatísticas calculadas
-  totalInvited  Int      @default(0)
-  totalConfirmed Int     @default(0)
-  totalDeclined Int      @default(0)
-  
-  // Concierge AI Context (RAG)
-  conciergeContext String? // JSON with menu, dress code, FAQs, etc.
-  
-  createdAt     DateTime @default(now())
-  updatedAt     DateTime @updatedAt
-  
-  // Relações
-  events        Event[]
-  guests        Guest[]
-  guestGroups   GuestGroup[]
-  invitations   Invitation[]
-  tables        Table[]
-  messages      MessageTemplate[]
-  accommodations Accommodation[]
-  transports    Transport[]
-  scheduledMessages ScheduledMessage[]
-  reminderConfigs  ReminderConfig[]
-  gifts         Gift[]
-  budgetItems   BudgetItem[]
-  vendors       Vendor[]
-  checklistItems ChecklistItem[]
-}
-
-// Sub-eventos (Cerimônia, Recepção, etc.)
-model Event {
-  id          String   @id @default(cuid())
-  weddingId   String
-  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  name        String   // "Cerimônia", "Recepção", "Jantar"
-  description String?
-  startTime   DateTime
-  endTime     DateTime?
-  venue       String?
-  address     String?
-  dressCode   String?
-  
-  // Capacidade
-  maxCapacity Int?
-  
-  // Ordernação
-  order       Int      @default(0)
-  
-  createdAt   DateTime @default(now())
-  updatedAt   DateTime @updatedAt
-  
-  // Relações
-  rsvps       Rsvp[]
-}
-
-// ============================================================================
-// GESTÃO DE CONVIDADOS - WhatsApp Concierge Architecture
-// ============================================================================
-
-// Invitation - Family/Group aggregator for WhatsApp conversations
-// Each invitation has ONE WhatsApp conversation but may have multiple guests
-model Invitation {
-  id          String   @id @default(cuid())
-  weddingId   String
-  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  // Primary contact for WhatsApp
-  primaryPhone      String   @unique  // WhatsApp number
-  primaryContactName String?           // "João Silva"
-  
-  // Family/Group name for personalized invites
-  familyName       String?  // "Família Silva"
-  
-  // WhatsApp conversation state
-  waConversationId String?  // WhatsApp Business API conversation ID
-  flowStatus       FlowStatus @default(none)
-  flowData         String?  // JSON: current flow state, collected data
-  
-  // Conversation memory for AI context
-  conversationSummary String? // AI-generated summary of conversation
-  lastMessageAt      DateTime?
-  
-  // QR Code for check-in (JWT token)
-  qrToken        String?  @unique
-  qrTokenExpires DateTime?
-  
-  // Check-in status
-  checkedIn      Boolean  @default(false)
-  checkedInAt    DateTime?
-  
-  createdAt      DateTime @default(now())
-  updatedAt      DateTime @updatedAt
-  
-  // Relações
-  guests         Guest[]
-  messageQueue   MessageQueue[]
-  conversations  ConversationMessage[]
-}
-
-// FlowStatus - State machine for WhatsApp Flows
-enum FlowStatus {
-  none            // No active flow
-  rsvp_flow       // Collecting RSVP responses
-  dietary_flow    // Collecting dietary restrictions
-  songs_flow      // Collecting song requests
-  confirmed       // All data collected
-  declined        // Declined invitation
-}
-
-// Guest - Individual person within an invitation
-model Guest {
-  id          String   @id @default(cuid())
-  weddingId   String
-  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  // Invitation reference (WhatsApp conversation owner)
-  invitationId   String?
-  invitation     Invitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
-  
-  // Grupo familiar (legacy - kept for table assignment)
-  groupId     String?
-  group       GuestGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
-  isGroupLeader Boolean @default(false)
-  
-  // Dados Pessoais
-  firstName   String
-  lastName    String
-  email       String?
-  phone       String?   // Individual phone (if different from invitation)
-  
-  // Foto (opcional)
-  avatarUrl   String?
-  
-  // Categoria/Onde conheceu
-  category    String?   // "Família", "Amigos", "Trabalho", "Conhecidos"
-  relationship String?  // "Primo do Noivo", "Colega da Noiva"
-  
-  // Status do convite
-  inviteStatus InviteStatus @default(pending)
-  inviteSentAt DateTime?
-  
-  // Preferências
-  dietaryRestrictions String?
-  specialNeeds     String?
-  songs            String?
-  
-  // AI Context - Conversation embedding for personalized responses
-  embeddingContext  String? // JSON: key facts about this guest for AI
-  
-  // Notas internas
-  notes       String?
-  
-  // Rastreamento de agradecimento (pós-evento)
-  thankYouSent   Boolean  @default(false)
-  thankYouSentAt DateTime?
-  
-  // Token único para RSVP (link do convite)
-  rsvpToken   String   @unique @default(cuid())
-  
-  createdAt   DateTime @default(now())
-  updatedAt   DateTime @updatedAt
-  
-  // Relações
-  rsvps       Rsvp[]
-  messages    MessageLog[]
-}
-
-// Conversation Message - Full conversation history for AI context
-model ConversationMessage {
-  id            String   @id @default(cuid())
-  invitationId  String
-  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
-  
-  // Message direction
-  direction     MessageDirection
-  
-  // Content
-  content       String   // Text content
-  mediaType     String?  // "image", "audio", "document"
-  mediaUrl      String?  // URL to media file
-  
-  // AI Processing metadata
-  intent        String?  // Detected intent: "confirm", "decline", "question", etc.
-  entities      String?  // JSON: extracted entities (names, dates, etc.)
-  functionCall  String?  // JSON: function called by AI
-  
-  // WhatsApp metadata
-  waMessageId   String?  @unique
-  timestamp     DateTime @default(now())
-  
-  createdAt     DateTime @default(now())
-}
-
-enum MessageDirection {
-  inbound   // From guest
-  outbound  // From concierge
-}
-
-// GuestGroup - Legacy group model for table assignment
-model GuestGroup {
-  id          String   @id @default(cuid())
-  weddingId   String
-  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  name        String
-  notes       String?
-  
-  // Atribuição de mesa
-  tableId     String?
-  table       Table?   @relation(fields: [tableId], references: [id])
-  
-  createdAt   DateTime @default(now())
-  updatedAt   DateTime @updatedAt
-  
-  guests      Guest[]
-}
-
-enum InviteStatus {
-  pending
-  sent
-  viewed
-  responded
-  reminder_sent
-}
-
-// ============================================================================
-// RSVP - Respostas
-// ============================================================================
-
-model Rsvp {
-  id          String   @id @default(cuid())
-  
-  guestId     String
-  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
-  
-  eventId     String
-  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
-  
-  // Status da resposta
-  status      RsvpStatus @default(pending)
-  
-  // Dados da resposta
-  respondedAt DateTime?
-  plusOne     Boolean  @default(false)
-  plusOneName String?
-  
-  // Mensagem dos noivos
-  guestMessage String?
-  
-  // Source tracking
-  responseSource String? // "whatsapp", "web", "manual"
-  
-  createdAt   DateTime @default(now())
-  updatedAt   DateTime @updatedAt
-  
-  @@unique([guestId, eventId])
-}
-
-enum RsvpStatus {
-  pending
-  confirmed
-  declined
-  maybe
-}
-
-// ============================================================================
-// ORGANIZAÇÃO DE MESAS
-// ============================================================================
-
-model Table {
-  id          String   @id @default(cuid())
-  weddingId   String
-  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  name        String
-  capacity    Int      @default(8)
-  shape       TableShape @default(round)
-  
-  positionX   Float?
-  positionY   Float?
-  
-  notes       String?
-  
-  createdAt   DateTime @default(now())
-  updatedAt   DateTime @updatedAt
-  
-  groups      GuestGroup[]
-}
-
-enum TableShape {
-  round
-  rectangular
-  square
-}
-
-// ============================================================================
-// MESSAGE QUEUE - Async processing with idempotency
-// ============================================================================
-
-model MessageQueue {
-  id            String   @id @default(cuid())
-  invitationId  String
-  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
-  
-  // Idempotency key for deduplication
-  idempotencyKey String   @unique
-  
-  // Message content
-  messageType   String   // "text", "image", "interactive", "template"
-  content       String   // JSON payload
-  
-  // Processing status
-  status        QueueStatus @default(pending)
-  attempts      Int      @default(0)
-  maxAttempts   Int      @default(3)
-  lastError     String?
-  
-  // Scheduling
-  scheduledFor  DateTime?
-  processedAt   DateTime?
-  
-  // WhatsApp response tracking
-  waMessageId   String?
-  
-  createdAt     DateTime @default(now())
-  updatedAt     DateTime @updatedAt
-}
-
-enum QueueStatus {
-  pending
-  processing
-  sent
-  failed
-  cancelled
-}
-
-// ============================================================================
-// MESSAGE SCHEDULER - Agendamento de Mensagens
-// ============================================================================
-
-model ScheduledMessage {
-  id            String   @id @default(cuid())
-  weddingId     String
-  wedding       Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  type          String   // "invitation", "reminder", "custom"
-  template      String   // Template name or content
-  
-  // Filters
-  recipientFilter String? // "all", "pending", "confirmed", "declined", specific group IDs
-  
-  // Scheduling
-  scheduledFor  DateTime
-  timezone      String   @default("America/Sao_Paulo")
-  
-  // Status
-  status        String   @default("pending") // "pending", "processing", "sent", "failed", "cancelled"
-  sentAt        DateTime?
-  error         String?
-  
-  // Stats
-  totalRecipients Int?
-  sentCount     Int      @default(0)
-  failedCount   Int      @default(0)
-  
-  createdAt     DateTime @default(now())
-  updatedAt     DateTime @updatedAt
-}
-
-// ============================================================================
-// REMINDER CONFIGURATION - Lembretes Automáticos
-// ============================================================================
-
-model ReminderConfig {
-  id            String   @id @default(cuid())
-  weddingId     String
-  wedding       Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  enabled       Boolean  @default(true)
-  
-  // First reminder
-  firstReminderDays  Int @default(30) // Days before wedding
-  
-  // Second reminder
-  secondReminderDays Int @default(7)  // Days before wedding
-  
-  // Final reminder
-  finalReminderDays  Int @default(2)  // Days before wedding
-  
-  // Message customization
-  customMessage String?
-  
-  createdAt     DateTime @default(now())
-  updatedAt     DateTime @updatedAt
-}
-
-// ============================================================================
-// COMUNICAÇÃO - Templates e Logs
-// ============================================================================
-
-model MessageTemplate {
-  id          String   @id @default(cuid())
-  weddingId   String
-  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
-  
-  name        String
-  type        MessageType
-  
-  subject     String?
-  content     String
-  
-  // Variables available for this template (JSON array)
-  variables   String?  // JSON array of variable names: ["nome", "familia", "parceiro1", ...]
-  
-  // Preview thumbnail
-  thumbnail   String?  // URL or base64 for preview image
-  
-  // WhatsApp template info
-  waTemplateName String?  // Official template name
-  waTemplateLanguage String? @default("pt_BR")
-  
-  isActive    Boolean  @default(true)
-  
-  createdAt   DateTime @default(now())
-  updatedAt   DateTime @updatedAt
-  
-  logs        MessageLog[]
-}
-
-enum MessageType {
-  email
-  whatsapp
-  sms
-}
-
-model MessageLog {
-  id          String   @id @default(cuid())
-  
-  guestId     String
-  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
-  
-  templateId  String?
-  template    MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
-  
-  type        MessageType
-  status      MessageStatus
-  
-  subject     String?
-  content     String
-  
-  response    String?
-  respondedAt DateTime?
-  
-  externalId  String?
-  
-  sentAt      DateTime @default(now())
-  createdAt   DateTime @default(now())
-}
-
-enum MessageStatus {
-  pending
-  sent
-  delivered
-  read
-  failed
-  bounced
-}
-
-// ============================================================================
-// LISTA DE PRESENTES - Gift Registry
-// ============================================================================
-
-model Gift {
